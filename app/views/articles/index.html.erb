<% content_for :title, "Articles" %>

<div class="page-header">
  <h1>Articles</h1>
  <div class="page-header__meta"><%= @articles.size %> <%= "article".pluralize(@articles.size) %></div>
</div>

<div class="search-bar">
  <%= form_with url: articles_path, method: :get do |f| %>
    <%= f.text_field :search, value: params[:search], placeholder: "Search title, content, author…", class: "search-bar__input", "aria-label": "Search" %>
    <%= f.select :status,
        options_for_select([["All", ""], ["Published", "published"], ["Drafts", "draft"]], params[:status]),
        {},
        class: "search-bar__select", "aria-label": "Status" %>
    <%= f.submit "Search", class: "btn btn-primary btn-sm" %>
    <% if params[:search].present? || params[:status].present? %>
      <%= link_to "Clear", articles_path, class: "btn btn-ghost btn-sm" %>
    <% end %>
  <% end %>
</div>

<% if @articles.any? %>
  <table class="article-list">
    <thead>
      <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Status</th>
        <th>Date</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @articles.each do |article| %>
        <tr class="article-row">
          <td class="article-row__title" data-label="Title">
            <%= link_to article.title, article %>
            <p class="article-row__excerpt"><%= truncate(article.content, length: 90) %></p>
          </td>
          <td class="article-row__author" data-label="Author"><%= article.author %></td>
          <td data-label="Status"><span class="badge <%= article.published ? 'badge--published' : 'badge--draft' %>"><%= article.published_status %></span></td>
          <td class="article-row__date" data-label="Date"><%= article.created_at.strftime("%d %b %Y") %></td>
          <td class="article-row__actions">
            <%= link_to "Edit", edit_article_path(article), class: "btn btn-ghost btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty-state">
    <% if params[:search].present? || params[:status].present? %>
      <p>No articles match your filters.</p>
      <%= link_to "Clear Filters", articles_path, class: "btn btn-ghost" %>
    <% else %>
      <p>No articles yet.</p>
      <%= link_to "+ Create your first article", new_article_path, class: "btn btn-primary" %>
    <% end %>
  </div>
<% end %>
